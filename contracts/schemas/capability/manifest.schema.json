{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.super-av.local/schemas/capability/manifest.schema.json",
  "title": "Phase 1 Capability Manifest",
  "type": "object",
  "required": ["deviceId", "manifestVersion", "adapters"],
  "properties": {
    "deviceId": { "$ref": "https://contracts.super-av.local/schemas/common.schema.json#/$defs/deviceId" },
    "manifestVersion": { "$ref": "https://contracts.super-av.local/schemas/common.schema.json#/$defs/contractVersion" },
    "adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["adapterType", "adapterVersion", "capabilities"],
        "properties": {
          "adapterType": { "type": "string", "enum": ["touchdesigner", "system_health"] },
          "adapterVersion": { "$ref": "https://contracts.super-av.local/schemas/common.schema.json#/$defs/semver" },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "version"],
              "properties": {
                "id": { "$ref": "https://contracts.super-av.local/schemas/common.schema.json#/$defs/logicalAction" },
                "version": { "$ref": "https://contracts.super-av.local/schemas/common.schema.json#/$defs/contractVersion" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
