{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.super-av.local/schemas/errors/error-catalogue.schema.json",
  "title": "Phase 1 Error Catalogue",
  "type": "object",
  "required": ["catalogueVersion", "errors"],
  "properties": {
    "catalogueVersion": { "$ref": "https://contracts.super-av.local/schemas/common.schema.json#/$defs/contractVersion" },
    "errors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["code", "category", "severity", "userSafeMessage", "diagnosticGuidance"],
        "properties": {
          "code": { "$ref": "https://contracts.super-av.local/schemas/common.schema.json#/$defs/errorCode" },
          "category": { "type": "string", "enum": ["Provisioning", "Pairing", "Authentication", "Command", "Capability", "Configuration", "Adapter", "Package"] },
          "severity": { "$ref": "https://contracts.super-av.local/schemas/common.schema.json#/$defs/errorSeverity" },
          "userSafeMessage": { "type": "string", "minLength": 1 },
          "diagnosticGuidance": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
