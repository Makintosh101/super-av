{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/commands/command-envelope.schema.json",
  "title": "Node Command Envelope",
  "type": "object",
  "required": [
    "commandId",
    "deviceId",
    "action",
    "issuedAt",
    "expiresAt",
    "parameters"
  ],
  "properties": {
    "commandId": {
      "type": "string"
    },
    "deviceId": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "configurationRevision": {
      "type": "integer",
      "minimum": 0
    },
    "idempotencyKey": {
      "type": "string"
    },
    "parameters": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
